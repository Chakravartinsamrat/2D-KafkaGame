# ─────────────────────────────────────────────────────────────────────────────
# 2D Kafka Game Server - Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ─── CORS Configuration ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
# Example for production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Kafka Configuration ─────────────────────────────────────────────────────
# Set to "false" to disable Kafka entirely (game still works)
KAFKA_ENABLED=true

# Kafka broker address
# Local: localhost:9092
# Upstash: your-endpoint.upstash.io:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka topic name
KAFKA_TOPIC=game-events

# ─── Cloud Kafka Authentication (Upstash, Confluent, etc.) ───────────────────
# Leave empty for local Kafka without authentication
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ─── Example Upstash Configuration ───────────────────────────────────────────
# KAFKA_BOOTSTRAP_SERVERS=your-cluster.upstash.io:9092
# KAFKA_SASL_USERNAME=your-upstash-username
# KAFKA_SASL_PASSWORD=your-upstash-password
